{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["vite/client"],
    "paths": {
      "@openblock/shared": ["../packages/shared/src/index.ts"],
      "@openblock/db": ["../packages/db/src/index.ts"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules"]
}
